<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main">
  <header class="topbar">
    <div class="flex items-center gap-2">
      <button class="menu-toggle" id="menuToggle">☰</button>
      <span class="topbar-title">Add New Book</span>
    </div>
    <a href="/books" class="btn btn-ghost btn-sm">← Back</a>
  </header>
  <div class="content">
    <div class="card" style="max-width:700px">
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form action="/books" method="POST">
        <div class="form-grid">
          <div class="form-group full">
            <label>Book Title *</label>
            <input type="text" name="title" required placeholder="Enter book title">
          </div>
          <div class="form-group">
            <label>Author *</label>
            <select name="author" required>
              <option value="">— Select Author —</option>
              <% authors.forEach(a => { %>
                <option value="<%= a._id %>"><%= a.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Genre *</label>
            <select name="genre" required>
              <option value="">— Select Genre —</option>
              <% ['Fiction','Non-Fiction','Science','History','Biography','Technology','Philosophy','Literature','Mystery','Other'].forEach(g => { %>
                <option value="<%= g %>"><%= g %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>ISBN</label>
            <input type="text" name="isbn" placeholder="9780000000000">
          </div>
          <div class="form-group">
            <label>Published Year</label>
            <input type="number" name="publishedYear" placeholder="2024" min="1000" max="2026">
          </div>
          <div class="form-group">
            <label>Total Copies *</label>
            <input type="number" name="totalCopies" value="1" min="1" required>
          </div>
          <div class="form-group">
            <label>Cover Color</label>
            <input type="color" name="coverColor" value="#4f46e5">
          </div>
          <div class="form-group full">
            <label>Description</label>
            <textarea name="description" placeholder="Brief description…"></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Save Book</button>
          <a href="/books" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
