<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main">
  <header class="topbar">
    <div class="flex items-center gap-2">
      <button class="menu-toggle" id="menuToggle">☰</button>
      <span class="topbar-title"><%= book.title %></span>
    </div>
    <div class="topbar-actions">
      <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'librarian')) { %>
        <a href="/books/<%= book._id %>/edit" class="btn btn-ghost btn-sm">Edit</a>
        <form action="/books/<%= book._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete this book?')">
          <button class="btn btn-danger btn-sm">Delete</button>
        </form>
      <% } %>
      <a href="/books" class="btn btn-ghost btn-sm">← Back</a>
    </div>
  </header>
  <div class="content">
    <div class="card" style="max-width:700px">
      <div style="display:flex;align-items:flex-start;gap:20px;margin-bottom:20px">
        <div style="width:80px;height:110px;border-radius:6px;background:<%= book.coverColor %>22;border:2px solid <%= book.coverColor %>;display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0">📖</div>
        <div>
          <h2 style="font-family:'Playfair Display',serif;font-size:22px;margin-bottom:4px"><%= book.title %></h2>
          <p style="color:var(--text-muted);margin-bottom:8px">by <a href="/authors/<%= book.author._id %>" style="color:var(--accent)"><%= book.author.name %></a></p>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <span class="badge badge-info"><%= book.genre %></span>
            <% if (book.availableCopies > 0) { %>
              <span class="badge badge-success"><%= book.availableCopies %> Available</span>
            <% } else { %>
              <span class="badge badge-danger">Not Available</span>
            <% } %>
          </div>
        </div>
      </div>
      <div class="detail-grid">
        <div class="detail-item"><label>ISBN</label><p><%= book.isbn || '—' %></p></div>
        <div class="detail-item"><label>Published Year</label><p><%= book.publishedYear || '—' %></p></div>
        <div class="detail-item"><label>Total Copies</label><p><%= book.totalCopies %></p></div>
        <div class="detail-item"><label>Available</label><p><%= book.availableCopies %></p></div>
        <div class="detail-item" style="grid-column:1/-1"><label>Description</label><p><%= book.description || '—' %></p></div>
      </div>
      <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'librarian') && book.availableCopies > 0) { %>
      <div style="margin-top:20px;padding-top:20px;border-top:1px solid var(--border)">
        <a href="/loans/new" class="btn btn-primary">Issue Loan</a>
      </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
