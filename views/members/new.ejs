<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main">
  <header class="topbar">
    <div class="flex items-center gap-2">
      <button class="menu-toggle" id="menuToggle">☰</button>
      <span class="topbar-title">Add Member</span>
    </div>
    <a href="/members" class="btn btn-ghost btn-sm">← Back</a>
  </header>
  <div class="content">
    <div class="card" style="max-width:600px">
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form action="/members" method="POST">
        <div class="form-grid">
          <div class="form-group full">
            <label>User Account *</label>
            <select name="user" required>
              <option value="">— Select User —</option>
              <% users.forEach(u => { %>
                <option value="<%= u._id %>"><%= u.name %> (<%= u.email %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Membership Type</label>
            <select name="membershipType">
              <option value="standard">Standard</option>
              <option value="premium">Premium</option>
              <option value="student">Student</option>
            </select>
          </div>
          <div class="form-group">
            <label>Phone</label>
            <input type="text" name="phone" placeholder="+1 555 000 0000">
          </div>
          <div class="form-group full">
            <label>Address</label>
            <textarea name="address" style="min-height:70px" placeholder="Street, City, Country"></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Create Member</button>
          <a href="/members" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
