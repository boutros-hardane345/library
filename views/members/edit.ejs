<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main">
  <header class="topbar">
    <div class="flex items-center gap-2">
      <button class="menu-toggle" id="menuToggle">☰</button>
      <span class="topbar-title">Edit Member</span>
    </div>
    <a href="/members/<%= member._id %>" class="btn btn-ghost btn-sm">← Cancel</a>
  </header>
  <div class="content">
    <div class="card" style="max-width:600px">
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form action="/members/<%= member._id %>?_method=PUT" method="POST">
        <div class="form-grid">
          <div class="form-group full">
            <label>Member</label>
            <input type="text" value="<%= member.user ? member.user.name : '—' %>" disabled style="opacity:0.5">
          </div>
          <div class="form-group">
            <label>Membership Type</label>
            <select name="membershipType">
              <% ['standard','premium','student'].forEach(t => { %>
                <option value="<%= t %>" <%= member.membershipType === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Status</label>
            <select name="isActive">
              <option value="on" <%= member.isActive ? 'selected' : '' %>>Active</option>
              <option value="off" <%= !member.isActive ? 'selected' : '' %>>Inactive</option>
            </select>
          </div>
          <div class="form-group">
            <label>Phone</label>
            <input type="text" name="phone" value="<%= member.phone || '' %>">
          </div>
          <div class="form-group full">
            <label>Address</label>
            <textarea name="address" style="min-height:70px"><%= member.address || '' %></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Update Member</button>
          <a href="/members/<%= member._id %>" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
