<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main">
  <header class="topbar">
    <div class="flex items-center gap-2">
      <button class="menu-toggle" id="menuToggle">☰</button>
      <span class="topbar-title">Authors</span>
    </div>
    <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'librarian')) { %>
      <a href="/authors/new" class="btn btn-primary btn-sm">+ Add Author</a>
    <% } %>
  </header>
  <div class="content">
    <div class="card">
      <% if (authors.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">✍</div>
          <p>No authors yet.</p>
          <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'librarian')) { %>
            <a href="/authors/new" class="btn btn-primary">Add First Author</a>
          <% } %>
        </div>
      <% } else { %>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Name</th><th>Nationality</th><th>Birth Year</th><th>Email</th><th></th></tr></thead>
          <tbody>
            <% authors.forEach(author => { %>
            <tr>
              <td><a href="/authors/<%= author._id %>" style="color:var(--accent);text-decoration:none;font-weight:500"><%= author.name %></a></td>
              <td><%= author.nationality || '—' %></td>
              <td><%= author.birthYear || '—' %></td>
              <td><%= author.email || '—' %></td>
              <td>
                <div class="flex gap-2">
                  <a href="/authors/<%= author._id %>" class="btn btn-ghost btn-sm">View</a>
                  <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'librarian')) { %>
                    <a href="/authors/<%= author._id %>/edit" class="btn btn-ghost btn-sm">Edit</a>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
