<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main">
  <header class="topbar">
    <div class="flex items-center gap-2">
      <button class="menu-toggle" id="menuToggle">☰</button>
      <span class="topbar-title">Add New Author</span>
    </div>
    <a href="/authors" class="btn btn-ghost btn-sm">← Back</a>
  </header>
  <div class="content">
    <div class="card" style="max-width:600px">
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form action="/authors" method="POST">
        <div class="form-grid">
          <div class="form-group full">
            <label>Full Name *</label>
            <input type="text" name="name" required placeholder="Author's full name">
          </div>
          <div class="form-group">
            <label>Nationality</label>
            <input type="text" name="nationality" placeholder="e.g. British">
          </div>
          <div class="form-group">
            <label>Birth Year</label>
            <input type="number" name="birthYear" placeholder="e.g. 1970" min="1000" max="2026">
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" placeholder="author@example.com">
          </div>
          <div class="form-group full">
            <label>Bio</label>
            <textarea name="bio" placeholder="Short biography…"></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Save Author</button>
          <a href="/authors" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
