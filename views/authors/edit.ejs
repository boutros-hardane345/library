<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main">
  <header class="topbar">
    <div class="flex items-center gap-2">
      <button class="menu-toggle" id="menuToggle">☰</button>
      <span class="topbar-title">Edit Author</span>
    </div>
    <a href="/authors/<%= author._id %>" class="btn btn-ghost btn-sm">← Cancel</a>
  </header>
  <div class="content">
    <div class="card" style="max-width:600px">
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form action="/authors/<%= author._id %>?_method=PUT" method="POST">
        <div class="form-grid">
          <div class="form-group full">
            <label>Full Name *</label>
            <input type="text" name="name" required value="<%= author.name %>">
          </div>
          <div class="form-group">
            <label>Nationality</label>
            <input type="text" name="nationality" value="<%= author.nationality || '' %>">
          </div>
          <div class="form-group">
            <label>Birth Year</label>
            <input type="number" name="birthYear" value="<%= author.birthYear || '' %>" min="1000" max="2026">
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" value="<%= author.email || '' %>">
          </div>
          <div class="form-group full">
            <label>Bio</label>
            <textarea name="bio"><%= author.bio || '' %></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Update Author</button>
          <a href="/authors/<%= author._id %>" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
